# Production Environment Variables for Frontend
# Update these after deploying backend to Vercel

# Backend API URL (base URL without /api - api-client adds it automatically)
VITE_API_URL=https://your-backend-name.vercel.app

# Optional: Analytics, etc.
# VITE_ANALYTICS_ID=your-analytics-id

# WebSocket URL for production (if using separate WS server)
# VITE_WS_URL=wss://your-backend-name.vercel.app
